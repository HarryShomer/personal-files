#!/bin/bash

#############################################
# Remove AUR package for aurutils and pacman
#
# Steps:
#   1. Remove from custom db
#   2. Pacman remove
#   3. Delete tar from /home/custompkgs
#   4. Delete cache
#
# arg $1 - package name
############################################


if [ -z "$1" ]; then
    echo "Usage: aur-remove <package>"
    exit 1
fi

repo-remove /home/custompkgs/custom.db.tar $1
sudo pacman -Rs $1
sudo rm /home/custompkgs/$1*
sudo rm /var/cache/pacman/pkg/$1*

